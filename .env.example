MYSQL_DATABASE=fund_keeper
MYSQL_ROOT_PASSWORD=local-root-only

DB_URL="jdbc:mysql://localhost:3306/fund_keeper?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC"
DB_USERNAME=fund_keeper
DB_PASSWORD=fund_keeper

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_STARTTLS=false

# 使用 `openssl rand -base64 32` 分别生成，两个值不能相同。
AUTH_JWT_SECRET_BASE64=replace-with-a-random-base64-secret
AUTH_VERIFICATION_SECRET_BASE64=replace-with-another-random-base64-secret

# 可选：个人开发环境的基金基础资料、交易日历和正式净值同步。
# eastmoney-public 免费但不是承诺稳定的正式开放 API，仅用于个人学习和开发。
FUND_REFERENCE_DATA_PROVIDER=eastmoney-public
FUND_REFERENCE_DATA_SYNC_ON_STARTUP=false
# 可选预热基金；真实持仓和待处理买入会自动加入同步范围。
FUND_REFERENCE_DATA_FUND_CODES=005827
FUND_REFERENCE_DATA_SCHEDULE_ENABLED=true
# 工作日 20:30 增量更新配置基金净值，周六 06:00 刷新全量目录和日历。
FUND_REFERENCE_DATA_DAILY_NAV_CRON="0 30 20 * * MON-FRI"
FUND_REFERENCE_DATA_FULL_REFRESH_CRON="0 0 6 * * SAT"

# 可选：个人开发环境盘中估值。默认关闭，开启后只在交易时段刷新活跃基金。
FUND_VALUATION_PROVIDER=eastmoney-public
FUND_VALUATION_REFRESH_ENABLED=false
FUND_VALUATION_REFRESH_DELAY_MS=60000
FUND_VALUATION_FUND_CODES=005827
FUND_VALUATION_DELAYED_AFTER=90s
FUND_VALUATION_STALE_AFTER=3m

# 可选替代：Tushare 三项接口当前都要求至少 2000 积分。
TUSHARE_TOKEN=
